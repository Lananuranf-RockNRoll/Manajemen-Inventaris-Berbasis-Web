# ============================================================
# InvenSys — Docker Environment Template
# Salin file ini: cp .env.docker.example .env
# Ganti semua nilai <...> dengan nilai asli
# JANGAN commit .env ke Git!
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_ENV=production
APP_KEY=                          # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost

# ── Database ─────────────────────────────────────────────────
DB_ROOT_PASSWORD=<ganti_password_root_mysql>
DB_DATABASE=inventory_system
DB_USERNAME=invensys
DB_PASSWORD=<ganti_password_db>

# ── Mail (SMTP Gmail — pakai App Password) ──────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<email_gmail_kamu@gmail.com>
MAIL_PASSWORD=<google_app_password_16_karakter>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=<email_gmail_kamu@gmail.com>
MAIL_FROM_NAME="InvenSys"
